{
  "name": "zenzic-vscode",
  "displayName": "Zenzic",
  "description": "Visual Studio Code extension for Zenzic LSP",
  "version": "0.21.0",
  "publisher": "pythonwoods",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "zenzic",
    "markdown",
    "mdx",
    "static analysis",
    "security"
  ],
  "icon": "assets/zenzic-icon.svg",
  "repository": {
    "type": "git",
    "url": "https://github.com/PythonWoods/zenzic-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/PythonWoods/zenzic-vscode/issues"
  },
  "homepage": "https://github.com/PythonWoods/zenzic-vscode",
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:mdx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zenzic.restartServer",
        "title": "Zenzic: Restart Server"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Zenzic",
      "properties": {
        "zenzic.executablePath": {
          "type": "string",
          "default": "zenzic",
          "description": "Path to the Zenzic executable or virtual environment binary."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build -- --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.0.0",
    "typescript": "~5.3.3"
  }
}
